rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /feedback/{feedbackId}/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
      allow read: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
