#include "Shared.xcconfig"

PRODUCT_NAME = GoVibeHostCli
PRODUCT_BUNDLE_IDENTIFIER = dev.govibe.host.cli
INFOPLIST_FILE = Config/GoVibeHostCli-Info.plist
GENERATE_INFOPLIST_FILE = NO
MACOSX_DEPLOYMENT_TARGET = 15.0
SDKROOT = macosx

// CLI-specific auth configuration (override in Shared.xcconfig.local)
GOVIBE_FIREBASE_API_KEY = DUMMY_FIREBASE_API_KEY
GOVIBE_GOOGLE_DEVICE_CLIENT_ID = DUMMY_GOOGLE_DEVICE_CLIENT_ID
GOVIBE_GOOGLE_DEVICE_CLIENT_SECRET = DUMMY_GOOGLE_DEVICE_CLIENT_SECRET
