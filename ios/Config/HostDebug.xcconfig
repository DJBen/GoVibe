#include "Shared.xcconfig"


CODE_SIGN_ENTITLEMENTS = Config/GoVibeHost.entitlements

PRODUCT_NAME = GoVibeHost
PRODUCT_DISPLAY_NAME = GoVibe Host
PRODUCT_BUNDLE_IDENTIFIER = dev.govibe.host
GOOGLE_CLIENT_ID = $(HOST_GOOGLE_CLIENT_ID)
GOOGLE_REVERSED_CLIENT_ID = $(HOST_GOOGLE_REVERSED_CLIENT_ID)
INFOPLIST_FILE = Config/GoVibeHost-Info.plist
GENERATE_INFOPLIST_FILE = NO
MACOSX_DEPLOYMENT_TARGET = 15.0
SDKROOT = macosx
