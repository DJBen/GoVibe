#include "Shared.xcconfig"

// Ad-hoc signing for local debug builds — avoids needing a provisioning profile
// or a specific Apple Development cert in the keychain.
CODE_SIGN_IDENTITY = -
CODE_SIGN_STYLE = Manual
PROVISIONING_PROFILE_SPECIFIER =

PRODUCT_NAME = GoVibeHost
PRODUCT_DISPLAY_NAME = GoVibe Host
PRODUCT_BUNDLE_IDENTIFIER = dev.govibe.host.debug
INFOPLIST_FILE = Config/GoVibeHost-Info.plist
GENERATE_INFOPLIST_FILE = NO
MACOSX_DEPLOYMENT_TARGET = 15.0
SDKROOT = macosx
